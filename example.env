# Repo Guardian environment checklist.
# Copy values into your local shell, hosting platform, or a private .env file.
# Do not commit real secrets.

# Runtime
NODE_ENV=development
PORT=3000

# Local-development bearer token fallback.
# Production must set a strong value and should keep ALLOW_LEGACY_API_KEY_AUTH=false.
API_SECRET_KEY=replace-with-a-long-random-secret
ALLOW_LEGACY_API_KEY_AUTH=false

# Browser fallback token for local development only.
# This is bundled into the Vite client when set, so do not use a production secret here.
VITE_API_SECRET_KEY=

# Session cookies for GitHub OAuth workspace access.
# Production must set SESSION_SECRET to a strong random value.
SESSION_COOKIE_NAME=repo_guardian_session
SESSION_SECRET=replace-with-a-long-random-session-secret

# Primary Postgres database.
# For Supabase, use the project connection string from Database settings.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/repo_guardian

# Optional integration-test database. Tests that require Postgres are skipped when unset.
TEST_DATABASE_URL=

# Optional when your Postgres provider requires SSL, including most hosted Supabase connections.
# PGSSLMODE=require

# GitHub API fallback token for read/write clients when installation auth is unavailable.
# Prefer GitHub App installation auth for production workspace flows.
GITHUB_TOKEN=

# GitHub App credentials for installation-backed repository reads and supervised writes.
GITHUB_APP_ID=
# Keep the PEM formatting intact in your secret manager or deployment environment.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# GitHub OAuth app credentials for workspace sign-in.
# Local callback: http://localhost:3000/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Optional local filesystem fallback/import paths for legacy run and plan artifacts.
REPO_GUARDIAN_RUN_STORE_DIR=
REPO_GUARDIAN_PLAN_STORE_DIR=

# Future Supabase integration placeholders.
# These are not read by the current app until Supabase-specific integration work lands.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only. Never expose this through VITE_* variables or browser code.
SUPABASE_SERVICE_ROLE_KEY=
# Server-only database password/connection helpers if you prefer composing DATABASE_URL elsewhere.
SUPABASE_DB_PASSWORD=
SUPABASE_DATABASE_URL=

# Future model-backed analysis placeholders.
# The current Milestone 9A product path is deterministic; leave unset until model-backed features are implemented.
OPENAI_API_KEY=
